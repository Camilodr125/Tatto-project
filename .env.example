# Copy this file to `.env` and replace with real EmailJS values.
# `.env` is gitignored — this file is safe to commit as a template.
#
# Production (Vercel): add the same three variables under Project → Settings →
# Environment Variables (Production), then Redeploy — Vite bakes VITE_* in at build time.

VITE_EMAILJS_PUBLIC_KEY=REPLACE_WITH_YOUR_PUBLIC_KEY
VITE_EMAILJS_SERVICE_ID=REPLACE_WITH_YOUR_SERVICE_ID
VITE_EMAILJS_TEMPLATE_ID=REPLACE_WITH_YOUR_TEMPLATE_ID
# Optional — separate EmailJS template for /consult; if omitted, consult form uses VITE_EMAILJS_TEMPLATE_ID
# VITE_EMAILJS_CONSULT_TEMPLATE_ID=REPLACE_WITH_CONSULT_TEMPLATE_ID
